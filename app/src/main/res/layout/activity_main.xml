<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="25dp">

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginTop="30dp"
            android:contentDescription="Logo Anjo"
            android:src="@drawable/foto_logo_anjo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Anjo Gestão"
            android:textColor="#FF9800"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginTop="15dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sistema de Controle Profissional"
            android:textColor="#888888"
            android:textSize="14sp"
            android:layout_marginBottom="40dp" />

        <Button
            android:id="@+id/btnnovoservico"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="Registrar Novo Serviço"
            android:textSize="16sp"
            android:backgroundTint="#FF9800"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btnVerServicos"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="Consultar Histórico"
            android:textSize="16sp"
            android:backgroundTint="#FF9800"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btnRelatorios"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="Gerar Relatórios PDF"
            android:textSize="16sp"
            android:backgroundTint="#FF9800" />

        <Button
            android:id="@+id/btnClienteBlack"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="💎 Área Cliente Black"
            android:textSize="16sp"
            android:backgroundTint="#000000"
            android:textColor="#FFD700"
            android:layout_marginTop="20dp" />

        <Button
            android:id="@+id/btnAbrirCheckIn"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:text="CHECK-IN / VISTORIA"
            android:backgroundTint="#FF9800"
            android:textColor="#000000"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"/>

    </LinearLayout>
</ScrollView>