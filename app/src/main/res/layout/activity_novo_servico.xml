<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REGISTRAR NOVO TRABALHO"
            android:textColor="#FF9800"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginBottom="25dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selecione a Loja:"
            android:textColor="#FF9800" />

        <Spinner
            android:id="@+id/spinnerLojas"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@android:drawable/btn_dropdown"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="15dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Modelo do Carro:"
            android:textColor="#FFFFFF" />

        <AutoCompleteTextView
            android:id="@+id/editModelo"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Ex: Corolla, Civic, Onix..."
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:backgroundTint="#FF9800"
            android:layout_marginBottom="20dp"
            android:completionThreshold="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Serviços de Insulfilm"
            android:textColor="#FF9800"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"/>

        <CheckBox android:id="@+id/cbSemParaBrisa"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Carro sem para-brisa (R$ 100,00)" android:textColor="#FFFFFF"/>

        <CheckBox android:id="@+id/cbCompleto"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Carro completo (R$ 150,00)" android:textColor="#FFFFFF"/>

        <CheckBox android:id="@+id/cbParaBrisa"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Apenas Para-brisa (R$ 50,00)" android:textColor="#FFFFFF"/>

        <CheckBox android:id="@+id/cbTraseiro"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Apenas Vidro Traseiro (R$ 50,00)" android:textColor="#FFFFFF"
            android:layout_marginBottom="10dp"/>

        <CheckBox
            android:id="@+id/cbPorPorta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Serviço por Porta (R$ 30,00 cada)"
            android:textColor="#FFFFFF" />

        <LinearLayout
            android:id="@+id/layoutExtraPorta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:paddingLeft="20dp"
            android:layout_marginBottom="10dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Qtd Portas:"
                android:textColor="#BBBBBB" />

            <EditText
                android:id="@+id/editQtdPortas"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="1"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:backgroundTint="#FF9800" />
        </LinearLayout>

        <CheckBox
            android:id="@+id/cbEnvelopamento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Envelopamento"
            android:textColor="#FFFFFF" />

        <LinearLayout
            android:id="@+id/layoutExtraEnvelopamento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingLeft="20dp"
            android:layout_marginBottom="10dp">

            <EditText
                android:id="@+id/editDetalheEnvelopamento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="O que foi envelopado?"
                android:textColorHint="#888888"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF9800"
                android:imeOptions="actionDone"
                android:importantForAutofill="no" />

            <EditText
                android:id="@+id/editValorEnvelopamento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Valor (R$)"
                android:inputType="numberDecimal"
                android:textColorHint="#888888"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF9800" />
        </LinearLayout>

        <CheckBox
            android:id="@+id/cbExtraordinario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Extraordinário (Residencial/Arq)"
            android:textColor="#FFFFFF" />

        <LinearLayout
            android:id="@+id/layoutExtraExtra"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingLeft="20dp"
            android:layout_marginBottom="20dp">

            <EditText
                android:id="@+id/editDetalheExtra"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Descreva o serviço extraordinário"
                android:textColorHint="#888888"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF9800"
                android:imeOptions="actionDone"
                android:importantForAutofill="no" />

            <EditText
                android:id="@+id/editValorExtra"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Valor (R$)"
                android:inputType="numberDecimal"
                android:textColorHint="#888888"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF9800" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="25dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOTAL: "
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtTotal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="R$ 0,00"
                android:textColor="#FF9800"
                android:textSize="48sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnSalvarServico"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:text="SALVAR NO DISPOSITIVO"
            android:backgroundTint="#FF9800"
            android:textColor="#000000"
            android:textStyle="bold"/>

    </LinearLayout>
</ScrollView>