<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💎 MODO CLIENTE BLACK"
            android:textColor="#FFD700"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginBottom="30dp"/>

        <EditText
            android:id="@+id/editNomeClienteBlack"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Nome Completo do Cliente"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:backgroundTint="#FFD700"
            android:layout_marginBottom="15dp" />

        <EditText
            android:id="@+id/editModeloBlack"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Modelo do Veículo"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:backgroundTint="#FFD700"
            android:layout_marginBottom="25dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selecione a Tecnologia Premium:"
            android:textColor="#FFD700"
            android:layout_marginBottom="10dp" />

        <RadioGroup
            android:id="@+id/rgTecnologia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="30dp">

            <RadioButton
                android:id="@+id/rbCeramica"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Anjo IR Block Nano Cerâmica (10 Anos)"
                android:textColor="#FFFFFF"
                android:buttonTint="#FFD700"
                android:checked="true" />

            <RadioButton
                android:id="@+id/rbCarbono"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Anjo IR Block Nano Carbono (5 Anos)"
                android:textColor="#FFFFFF"
                android:buttonTint="#FFD700" />
        </RadioGroup>

        <Button
            android:id="@+id/btnGerarCartaoBlack"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:text="GERAR CERTIFICADO BLACK"
            android:backgroundTint="#FFD700"
            android:textColor="#000000"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>